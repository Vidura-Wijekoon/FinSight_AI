# ============================================================
# FinSight AI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Security ---
SECRET_KEY=your-super-secret-64-char-hex-key-change-this-immediately
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# --- Admin Credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# --- LLM (local-first: Ollama + llama3.1:8b, no external API needed) ---
LLM_PROVIDER=ollama
GEMINI_API_KEY=                     # only needed if LLM_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Embedding (fully local, no API key needed) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB Vector Store ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=finsight_docs

# --- File Paths ---
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
LOG_FILE=./logs/rag_audit.log
ENCRYPTION_KEY_PATH=./keys/secret.key

# --- Ingestion Limits ---
MAX_FILE_SIZE_MB=50
